# Airflow
AIRFLOW_UID=50000
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_WEBSERVER_SECRET_KEY=airflow-secret-key-change-in-production
AIRFLOW_API_SECRET_KEY=airflow-secret-key-change-in-production
AIRFLOW_INTERNAL_API_SECRET_KEY=airflow-internal-api-secret-key
AIRFLOW_JWT_SECRET=airflow-jwt-secret-change-in-production
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Or run: python scripts/generate_fernet_key.py

# MySQL (Control Plane)
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=control_plane
MYSQL_PASSWORD=control_plane
MYSQL_DATABASE=control_plane

# PostgreSQL (Airflow metadata)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# MongoDB
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=root
MONGO_DATABASE=test_database

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Redis (transient credential vault)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CDC=cdc.integration.events

# Control Plane
DATABASE_URL=mysql+pymysql://control_plane:control_plane@localhost:3306/control_plane
AIRFLOW_API_URL=http://localhost:8080/api/v2

# Security (change in production)
SECRET_KEY=your-secret-key-here-change-in-production
AUTH_ENABLED=false

# OpenTelemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=control-plane-service
