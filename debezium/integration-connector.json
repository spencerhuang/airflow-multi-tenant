{
  "name": "integration-cdc-connector",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "tasks.max": "1",
    "database.hostname": "mysql",
    "database.port": "3306",
    "database.user": "control_plane",
    "database.password": "control_plane",
    "database.server.id": "184054",
    "topic.prefix": "cdc",
    "database.include.list": "control_plane",
    "table.include.list": "control_plane.integrations",
    "schema.history.internal.kafka.bootstrap.servers": "kafka:29092",
    "schema.history.internal.kafka.topic": "schema-changes.control_plane",
    "include.schema.changes": "false",
    "snapshot.mode": "when_needed",
    "database.connectionTimeZone": "UTC",
    "time.precision.mode": "connect",
    "decimal.handling.mode": "double",
    "bigint.unsigned.handling.mode": "long",
    "transforms": "unwrap,route",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "false",
    "transforms.unwrap.delete.handling.mode": "rewrite",
    "transforms.unwrap.add.fields": "op,source.ts_ms,source.db,source.table",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "cdc\\.control_plane\\.integrations",
    "transforms.route.replacement": "cdc.integration.events",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false"
  }
}
